# Gemini API (Blog AI üretimi)
# Google AI Studio > https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@fizyotech.com

# Firebase Cloud Messaging (push bildirimleri)
# Firebase Console > Project Settings > Service accounts > "Generate new private key"
# ile inen JSON dosyasının yolu. Boş bırakılırsa push bildirimleri devre dışı kalır.
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Randevu hatırlatmaları (24 saat ve 1 saat öncesi) bir yönetim komutu ile
# gönderilir. Periyodik çalışması için crontab'a ekleyin (örn. her 10 dk):
#   */10 * * * * cd /path/to/backend && /path/to/venv/bin/python \
#       manage.py send_appointment_reminders >> /tmp/fizyotech_reminders.log 2>&1

# Blog AI üretimi — 3 günde bir çalıştırın (örn. Cuma sabahı 08:00):
#   0 8 */3 * * cd /path/to/backend && /path/to/venv/bin/python \
#       manage.py generate_scheduled_blogs >> /tmp/blog_generate.log 2>&1


